# Arbiter environment variables
# Copy this file to .env and fill in real values — never commit .env

# Anthropic API key — required when use_mock=False in RoutingAgent
# Get it at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# Context Service host/port (used by ContextAPI client)
# Default: http://localhost:8000
ARBITER_CONTEXT_SERVICE_URL=http://localhost:8000

# FastAPI server settings (used by `make serve`)
ARBITER_HOST=0.0.0.0
ARBITER_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
